# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: news cache writes + bypass RLS when needed (recommended for /api/news refresh)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site URL for auth redirects (magic link + email confirmation)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NewsAPI.org (optional — without it, /api/news serves cache-only / friendly empty state)
NEWS_API_KEY=

# Resend — email when someone submits a memory for approval (gallery only)
RESEND_API_KEY=
# Sender must be allowed in Resend (e.g. onboarding@resend.dev for tests, or your verified domain)
RESEND_FROM_EMAIL=onboarding@resend.dev
# Inbox that receives “new memory pending” messages
GALLERY_NOTIFY_EMAIL=

# Cron: purge cinema / poetry / gallery posts older than 100 hours (Vercel Cron sends Authorization: Bearer …)
CRON_SECRET=

# Phase 3 — Playground
# WhoFits: full URL; home page shows copy + link only (opens in a new tab)
NEXT_PUBLIC_WHOFITS_URL=
# Lichess puzzle IDs for side-by-side trainers (https://lichess.org/training/{id})
NEXT_PUBLIC_LICHESS_PUZZLE_MATE2=Kbg4l
NEXT_PUBLIC_LICHESS_PUZZLE_MATE3=3HyMN

# OpenWeather current weather (optional — /api/weather)
OPENWEATHER_API_KEY=
# e.g. Kadapa,IN (default) or Yacharam,IN
WEATHER_QUERY=

# CricketData / CricAPI current matches (optional — /api/cricket). Any one key name works:
CRICKET_API_KEY=
# CRIC_API_KEY=
# CRICAPI_API_KEY=
